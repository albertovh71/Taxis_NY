# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
.Python
build/
dist/
*.egg-info/
*.egg

# Virtual environments
.venv/
venv/
env/
ENV/

# Environment variables / secrets
.env
.env.*
!.env.example

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# IDEs
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
desktop.ini

# Testing / coverage
.pytest_cache/
.coverage
htmlcov/
.tox/
.mypy_cache/
.ruff_cache/

# Data (no versionar datasets pesados — mantener solo .gitkeep)
data/raw/*
data/interim/*
data/processed/*
data/external/*
!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep
!data/external/.gitkeep

# Modelos entrenados (pesados — usar DVC/MLflow si es necesario)
models/*
!models/.gitkeep
*.pkl
*.joblib
*.h5
*.pt
*.pth
*.onnx

# Figuras generadas
reports/figures/*
!reports/figures/.gitkeep

# MLflow / experimentos
mlruns/
mlartifacts/

# Logs
*.log
logs/

# Claude Code local settings
.claude/

# Streamlit local config
.streamlit/
